# Copy to .env and fill in. Never commit .env to version control.

# Required for synthesis and article generation (OpenAI or Anthropic)
OPENAI_API_KEY=sk-...

# Optional: Anthropic for synthesis/generation
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: Semantic Scholar API key (higher rate limit)
# SEMANTIC_SCHOLAR_API_KEY=...

# Optional: custom config path
# ARTICLEWRITER_CONFIG=config/custom.yaml
